# Copy to `.env` and fill in. `.env` is gitignored — never commit real secrets.

# Required for the LLM stages (triage, review, fix, tests). The sandbox needs no key.
OPENAI_API_KEY=sk-...

# Optional: a pull-request-write-scoped token. Blank/unset = suggestions are rendered but not posted.
GITHUB_TOKEN=

# Optional overrides (see application.yaml for the full set). Spring relaxed binding maps these:
#   SANDBOX_WORK_ROOT           -> sandbox.work-root
#   SANDBOX_LOCAL_MAVEN_REPO    -> sandbox.local-maven-repo   (pre-warmed .m2 for offline builds)
#   CODE_REVIEW_AUTO_APPLY_MODE -> code-review.auto-apply.mode (SUGGEST | COMMIT | AUTOFIX_ONLY)
# SANDBOX_LOCAL_MAVEN_REPO=/work/.m2/repository
